<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/CardStyle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Worker Icon -->
        <ImageView
            android:id="@+id/img_worker"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/ic_labor"
            android:backgroundTint="@color/text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_labor_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Raju Kumar"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            app:layout_constraintStart_toEndOf="@id/img_worker"
            app:layout_constraintEnd_toStartOf="@id/tv_labor_wage"
            app:layout_constraintTop_toTopOf="@id/img_worker" />

        <TextView
            android:id="@+id/tv_labor_skill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sowing Expert"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toStartOf="@id/tv_labor_name"
            app:layout_constraintTop_toBottomOf="@id/tv_labor_name" />

        <!-- Rating Bar -->
        <RatingBar
            android:id="@+id/rating_labor"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:rating="4.5"
            android:layout_marginTop="4dp"
            android:progressTint="#FFC107"
            app:layout_constraintStart_toStartOf="@id/tv_labor_skill"
            app:layout_constraintTop_toBottomOf="@id/tv_labor_skill" />

        <TextView
            android:id="@+id/tv_member_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 Members"
            android:textSize="12sp"
            android:textColor="@color/primary_green"
            android:background="@drawable/rounded_bg_gray"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@id/rating_labor"
            app:layout_constraintTop_toBottomOf="@id/rating_labor"/>

        <!-- Wage -->
        <TextView
            android:id="@+id/tv_labor_wage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹500 / Day"
            android:textStyle="bold"
            android:textColor="@color/primary_green"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Actions -->
        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_member_count"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_call_worker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="కాల్ (Call)"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/secondary_blue"
                android:textColor="@color/secondary_blue"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_hire_worker"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="ఇప్పుడు నియమించు (Hire Now)"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary_green"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
