<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDashboard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#2E7D32"> 

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iconTractor"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_equipment" 
            android:layout_centerVertical="true"
            app:tint="@android:color/white"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iconTractor"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/tvDashboardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="పరికరాల అభ్యర్థనలు (Equipment Requests)"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"/>

            <TextView
                android:id="@+id/tvRequestCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 పెండింగ్ అభ్యర్థనలు (Pending Requests)"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvOngoingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 కొనసాగుతున్న బుకింగ్‌లు (Ongoing Bookings)"
                android:textSize="16sp"
                android:textColor="#E0F2F1"
                android:layout_marginTop="2dp"/>
                
             <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="అభ్యర్థనలు చూడండి (View Requests) ->"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:layout_marginTop="8dp"
                android:layout_gravity="end"/>
        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
