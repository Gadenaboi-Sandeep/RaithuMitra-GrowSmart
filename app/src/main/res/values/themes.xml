<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme using Material 3 -->
    <style name="Theme.RaithuMitra" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryContainer">@color/primary_green_light</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondary_blue</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/background_sage</item>
        <item name="colorSurface">@color/surface_white</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_green_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Typography Defaults -->
        <item name="android:fontFamily">sans-serif</item> <!-- Roboto -->
    </style>
    
    <!-- Card Style -->
    <style name="CardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/surface_white</item>
    </style>
</resources>
